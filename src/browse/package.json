{
  "name": "browse",
  "version": "0.1.0",
  "description": "Fast headless browser skill for Claude Code — persistent Chromium daemon via Playwright.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "browse": "../../.claude/skills/browse/browse"
  },
  "scripts": {
    "build": "bun build --compile src/cli.ts --outfile ../../.claude/skills/browse/browse",
